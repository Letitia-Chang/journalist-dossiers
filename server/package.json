{
  "name": "northstar-server",
  "version": "1.0.0",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:create": "node-pg-migrate create --",
    "migrate:up": "node -r dotenv/config node_modules/.bin/node-pg-migrate up",
    "migrate:down": "node -r dotenv/config node_modules/.bin/node-pg-migrate down"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "googleapis": "^173.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.5.0",
    "pg": "^8.22.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.20.0",
    "node-pg-migrate": "^8.0.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
